generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Document {
  id               String   @id @default(uuid())
  fileName         String
  fileType         String   @default("application/pdf")
  filePath         String   // physical path in ./uploads
  category         String   @default("INVOICE")
  status           String   @default("UPLOADED")
  // UPLOADED → EXTRACTING → EXTRACTED → VERIFYING → VERIFIED → FLAGGED
  extractedData    String?  // JSON string
  complianceScore  Int?
  complianceReport String?  // JSON string
  uploadedBy       String?
  projectId        String?  // Linked project
  project          Project? @relation(fields: [projectId], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Alert {
  id           String    @id @default(uuid())
  type         String    // DEADLINE | LAW_CHANGE | FLAGGED_DOC | SYSTEM
  severity     String    // critical | warning | info
  title        String
  message      String
  relatedDocId String?   // References Document
  isRead       Boolean   @default(false)
  deadline     DateTime?
  createdAt    DateTime  @default(now())
}

model LawUpdate {
  id            String    @id @default(uuid())
  title         String
  text          String
  summary       String
  category      String    // GST | LABOR | MCA | INCOME_TAX
  section       String?
  tags          String?   // JSON array
  sourceUrl     String?
  effectiveDate DateTime?
  vectorId      String?   // Reference to Qdrant point ID
  createdAt     DateTime  @default(now())
}

model SystemLog {
  id          String   @id @default(uuid())
  eventType   String   // DOCUMENT_UPLOADED | AI_CHECK_RUN
  username    String   // Name of the user performing the action
  details     String?  // Optional JSON string for extra info
  createdAt   DateTime @default(now())
}

model Project {
  id           String   @id @default(uuid())
  name         String
  client       String?
  status       String   @default("PLANNING") // PLANNING | ACTIVE | COMPLETED
  compliances  String?  // JSON string of selected compliances (array of objects)
  createdBy    String   // User name or ID
  documents    Document[]
  timelineType String?  // MONTH | DATE | RELATIVE | RANGE
  startDate    DateTime?
  endDate      DateTime?
  duration     String?   // e.g. "1 month"
  lastUpdated  DateTime @updatedAt
  createdAt    DateTime @default(now())
}

model PolicyEvaluation {
  id               String   @id @default(uuid())
  policyName       String
  policyFilePath   String
  selectedLaws     String   // JSON string: array of {id, title, section}
  complianceScore  Int?
  overallSummary   String?
  detailedResults  String?  // JSON string: array of evaluations
  status           String   @default("PENDING") // PENDING | COMPLETED | FAILED
  evaluatedBy      String?
  createdAt        DateTime @default(now())
}

